# Port du serveur API
PORT=4000

# Dossier des données (chemins relatifs au dossier backend/)
DATA_DIR=./data
UPLOAD_DIR=./uploads

# Base de données PostgreSQL (si défini, le backend utilise PostgreSQL au lieu des fichiers JSON)
# Exemple : postgresql://postgres:motdepasse@localhost:5432/stannys
# DATABASE_URL=

# Origines autorisées pour CORS (séparées par des virgules) : PC + tablette
# Exemple : http://localhost:3000,http://192.168.100.66:3000
FRONTEND_ORIGIN=http://localhost:3000

# Cloudinary (pour migration des images et upload futur)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
